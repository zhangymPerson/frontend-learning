{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "outDir": "./js",
    "rootDir": "./ts",
    "strict": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "declaration": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "lib": ["ES2020", "DOM"]
  },
  "include": ["ts/**/*.ts"]
}
